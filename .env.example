# Пример файла переменных окружения
# Скопируйте этот файл в .env и заполните своими значениями

# Порт сервера
PORT=3000

# Секретный ключ для JWT (сгенерируйте надёжный ключ!)
# Используйте: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this-in-production

# Окружение (development или production)
NODE_ENV=production

# Google OAuth Client ID
GOOGLE_CLIENT_ID=your-google-client-id-here

# База данных (SQLite)
DB_PATH=./users.db
